# Database access is via Supabase PostgREST (HTTPS). No DATABASE_URL / direct Postgres port is required.

# Supabase — https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# “anon” / “publishable” client key (sb_publishable_… is OK here). Never use the service_role key in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Required for ingest, webhooks, cron, admin DB queries, and scripts (db:check / db:seed).
# Never expose this in client bundles or the browser.
SUPABASE_SERVICE_ROLE_KEY=
# If your tooling only sets a publishable default name, the app also reads (optional):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Comma-separated emails that may access admin when metadata roles are not set yet
ADMIN_BOOTSTRAP_EMAILS=

# Geotravel Data API — docs: https://geotraveldata.com/api-docs
# One key per external client. Set in Vercel env vars for production.
GEOTRAVEL_API_KEY=

# Stub CRM / ingestion
INGEST_SECRET=change-me-in-production

# CRM write-back: stub (default) or tg4travel (TG4 Travel Partners API)
# API docs: https://webhook.backoffice.tg4travel.com/index.html#/
CRM_MODE=stub
TG4TRAVEL_API_BASE_URL=https://webhook.backoffice.tg4travel.com/api
# Single static Bearer token provided by TG4Travel/Activ Global — no OAuth exchange needed.
TG4TRAVEL_BEARER_TOKEN=

# Meta WhatsApp Cloud API — https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# Webhook callback URL (Meta dashboard): {NEXT_PUBLIC_APP_URL}/api/webhooks/whatsapp
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
# System User permanent token or temporary token from Graph API Explorer (keep secret).
WHATSAPP_ACCESS_TOKEN=
# GET verify + optional POST signature check (recommended in production).
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# Default language for template sends (e.g. hello_world → en_US).
WHATSAPP_DEFAULT_TEMPLATE_LANGUAGE=en_US
# Optional: E.164 without + for scripts/whatsapp-smoke.ts (e.g. 351930478387).
WHATSAPP_TEST_TO_E164=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_STATUS_CALLBACK_URL=

# AI (OpenAI-compatible; set base URL if using another provider)
OPENAI_API_KEY=

# Scheduling (Vercel Cron sends this header)
CRON_SECRET=

# App URL for webhooks (production / ngrok)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Quiet hours (24h local server TZ by default)
QUIET_HOURS_START_HOUR=22
QUIET_HOURS_END_HOUR=7
MAX_OUTBOUND_ATTEMPTS=5
RETRY_BASE_MINUTES=120
