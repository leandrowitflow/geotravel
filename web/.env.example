# Database (Postgres — local or Neon)
DATABASE_URL=postgresql://user:pass@localhost:5432/geotravel

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: comma-separated emails that may access admin before metadata roles are set
ADMIN_BOOTSTRAP_EMAILS=

# Stub CRM / ingestion
INGEST_SECRET=change-me-in-production

# CRM write-back: stub (default) or tg4travel (TG4 Travel Partners API)
# API docs: https://webhook.backoffice.tg4travel.com/index.html#/
CRM_MODE=stub
TG4TRAVEL_API_BASE_URL=https://webhook.backoffice.tg4travel.com/api
TG4TRAVEL_CLIENT_ID=
TG4TRAVEL_CLIENT_SECRET=
# Optional OAuth scope if required by tenant
# TG4TRAVEL_OAUTH_SCOPE=
# Field name on saveBooking payload for agent notes (match Swagger schema)
TG4TRAVEL_NOTES_FIELD=specialInstructions
# POST or PUT — match Swagger for v2/saveBooking
TG4TRAVEL_SAVE_BOOKING_METHOD=PUT
# If the API requires customerReference on every save, set it (or extend ingest to store it)
# TG4TRAVEL_CUSTOMER_REFERENCE=
# Merge static JSON into every saveBooking body (e.g. {"source":"geotravel_agent"})
# TG4TRAVEL_SAVE_BOOKING_EXTRA_JSON=

# Meta WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_STATUS_CALLBACK_URL=

# AI (OpenAI-compatible; set base URL if using another provider)
OPENAI_API_KEY=

# Scheduling (Vercel Cron sends this header)
CRON_SECRET=

# App URL for webhooks (production / ngrok)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Quiet hours (24h local server TZ by default)
QUIET_HOURS_START_HOUR=22
QUIET_HOURS_END_HOUR=7
MAX_OUTBOUND_ATTEMPTS=5
RETRY_BASE_MINUTES=120
